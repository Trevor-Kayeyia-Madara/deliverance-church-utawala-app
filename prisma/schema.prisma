generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sermons   Sermon[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sermon {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  description     String?
  speaker         String?
  date            DateTime
  durationMinutes Int?
  thumbnailUrl    String?
  videoUrl        String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, date])
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  createdAt DateTime @default(now())
}

model Donation {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  amount    Decimal  @db.Decimal(10, 2)
  currency  String   @default("KES")
  note      String?
  method    String?  // optional (e.g. "mpesa", "card", "bank")
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  location    String?
  posterUrl   String?
  startAt     DateTime
  endAt       DateTime?
  isPublished Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished, startAt])
}

model Pastor {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  roleTitle   String?
  bio         String?
  photoUrl    String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished, sortOrder, name])
}

model SiteSettings {
  id           Int     @id @default(autoincrement())
  siteName     String  @default("Deliverance Church Utawala")
  shortName    String  @default("DC Utawala")
  tagline      String  @default("The Church of Choice")
  location     String  @default("Utawala, Nairobi, Kenya")
  logoUrl      String?

  addressLine1 String?
  addressLine2 String?
  phoneDisplay String?
  phoneTel     String?
  email        String?

  youtubeUrl   String?
  facebookUrl  String?
  instagramUrl String?
  tiktokUrl    String?
  linktreeUrl  String?
  liveEmbedUrl String?

  serviceTimes Json?
  school       Json?
  giving       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String?
  imageUrl    String
  altText     String?
  caption    String?
  category   String?  // e.g., "services", "events", "youth", "outreach"
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished, sortOrder])
}

model Ministry {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  highlights  Json?
  imageUrl    String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished, sortOrder, title])
}
